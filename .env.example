# Docker image to use for simulations
DOCKER_IMAGE=ghcr.io/n-tehranchi/opensimroot-drought:latest

# Run:ai cluster settings
RUNAI_PROJECT=busch-lab
RUNAI_NAMESPACE=runai-busch-lab

# Resource limits per job
CPU_COUNT=2
MEMORY_LIMIT=4Gi
GPU_COUNT=0

# PVC (persistent volume claim) for input/output data
PVC_NAME=opensimroot-data
PVC_MOUNT=/sim

# Set to "true" to print commands without submitting
DRY_RUN=false
